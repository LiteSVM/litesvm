{
	"compilerOptions": {
		"declaration": true,
		"module": "CommonJS",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"target": "es2020",
		"noImplicitAny": true,
		"sourceMap": true,
		"outDir": "dist",
		"allowJs": true,
		"baseUrl": "./litesvm",
		"paths": {
			"litesvm": ["./"],
			"litesvm/kit": ["./kit"],
			"litesvm/web3js": ["./web3js"],
			"@/*": ["../*"]
		},
		"resolveJsonModule": true,
		"skipLibCheck": true
	},
	"include": ["litesvm/**/*"]
}
