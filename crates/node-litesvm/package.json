{
	"name": "litesvm",
	"version": "1.3.0",
	"main": "dist/cjs/kit.js",
	"module": "dist/esm/kit.js",
	"types": "dist/types/kit.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/kit.d.ts",
			"import": "./dist/esm/kit.js",
			"require": "./dist/cjs/kit.js"
		},
		"./kit": {
			"types": "./dist/types/kit.d.ts",
			"import": "./dist/esm/kit.js",
			"require": "./dist/cjs/kit.js"
		},
		"./web3js": {
			"types": "./dist/types/web3js.d.ts",
			"import": "./dist/esm/web3js.js",
			"require": "./dist/cjs/web3js.js"
		}
	},
	"files": ["dist/"],
	"sideEffects": false,
	"napi": {
		"binaryName": "litesvm",
		"targets": [
			"x86_64-apple-darwin",
			"x86_64-unknown-linux-gnu",
			"x86_64-unknown-linux-musl",
			"aarch64-apple-darwin",
			"aarch64-unknown-linux-gnu",
			"aarch64-unknown-linux-musl"
		]
	},
	"license": "MIT",
	"dependencies": {
		"@solana-program/system": "^0.12.2",
		"@solana-program/token": "^0.14.0",
		"@solana/kit": "^7.0.0",
		"@solana/web3.js": "3.0.0-rc.2"
	},
	"devDependencies": {
		"@algolia/client-search": "^5.55.0",
		"@napi-rs/cli": "^3.7.2",
		"@types/markdown-it": "^14.1.2",
		"@types/node": "22.19.21",
		"@types/node-fetch": "^2.6.13",
		"markdown-it": "^14.2.0",
		"markdown-it-include": "^2.0.0",
		"rome": "^12.1.3",
		"search-insights": "^2.17.3",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typedoc": "^0.28.19",
		"typedoc-plugin-markdown": "^4.12.0",
		"typedoc-vitepress-theme": "^1.1.3",
		"typescript": "^5.9.3",
		"vitepress": "^1.6.4",
		"ws": "^8.21.0"
	},
	"engines": {
		"node": ">= 20"
	},
	"scripts": {
		"artifacts": "napi artifacts",
		"build": "yarn build:napi:cjs && yarn build:napi:esm",
		"build:napi:cjs": "napi build --platform --release --output-dir dist/cjs --dts internal.d.ts --js internal.js",
		"build:napi:esm": "napi build --platform --release --output-dir dist/esm --dts internal.d.ts --js internal.js --esm",
		"build:debug": "napi build --platform litesvm --dts internal.d.ts --js internal.js",
		"prepublishOnly": "napi prepublish -t npm",
		"fmt": "yarn fmt:rust && yarn fmt:js",
		"fmt:rust": "cargo fmt",
		"fmt:js": "rome format --write litesvm/index.ts litesvm/kit.ts litesvm/web3js.ts scripts/ tests/ tsconfig.json tsconfig.cjs.json tsconfig.esm.json tsconfig.types.json package.json",
		"lint": "yarn lint:rust && yarn lint:js",
		"lint:rust": "cargo clippy",
		"lint:js": "rome check litesvm/index.ts litesvm/kit.ts litesvm/web3js.ts scripts/ tests/ tsconfig.json tsconfig.cjs.json tsconfig.esm.json tsconfig.types.json package.json",
		"test": "node -r ts-node/register -r tsconfig-paths/register --max-old-space-size=4096 --test --test-concurrency=1 tests/*.test.ts",
		"build:js": "yarn build:js:cjs && yarn build:js:esm && yarn build:types && yarn build:js:package-types",
		"build:js:cjs": "tsc --project tsconfig.cjs.json",
		"build:js:esm": "tsc --project tsconfig.esm.json",
		"build:js:package-types": "node scripts/package-types.js",
		"build:types": "tsc --project tsconfig.types.json && cp litesvm/internal.d.ts dist/types/internal.d.ts",
		"universal": "napi universal",
		"cargoBump": "cargo set-version --package litesvm-node --bump",
		"bumpPatch": "yarn version patch && napi version && cargo tree",
		"bumpMinor": "yarn version minor && napi version && cargo tree",
		"bumpMajor": "yarn version major && napi version && cargo tree",
		"predocs": "typedoc",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs"
	},
	"packageManager": "yarn@4.10.3"
}